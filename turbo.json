{
    "$schema": "https://turbo.build/schema.json",
    "ui": "stream",
    "globalDependencies": ["**/.env.*local"],
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs": ["$TURBO_DEFAULT$", ".env*"],
        "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
      },
      "dev": {
        "cache": false,
        "persistent": true,
        "dependsOn": ["^build"]
      },
      "check-types": {
        "dependsOn": ["^build"]
      },
      "push": { "cache": false }
    }
  }