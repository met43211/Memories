{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalDependencies": ["**/.env.*local"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**"]
		},
		"test": { "dependsOn": ["^build"], "outputs": [] },
		"dev": {
			"cache": false,
			"persistent": true,
			"dependsOn": ["^build"]
		},
		"check-types": {
			"dependsOn": ["^build"]
		},
		"dma": {
			"outputs": []
		},
		"push": { "cache": false },
		"db:up": { "cache": false },
		"db:reset": { "cache": false },
		"migrate": { "cache": false },
		"seed": { "cache": false, "dependsOn": ["migrate"] }
	}
}
